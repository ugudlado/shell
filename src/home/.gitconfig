# Include user-specific config from ~/.gitconfig.local
[include]
	path = ~/.gitconfig.local

[merge]
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait $MERGED
[diff]
	tool = vscode
        algorithm = histogram
        colorMoved = plain
        mnemonicPrefix = true
        renames = true
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[pull]
	rebase = false

[column]
        ui = auto
[branch]
        sort = -committerdate
[tag]
        sort = version:refname
[init]
	defaultBranch = main
[push]
	default = simple
        autoSetupRemote = true
        followTags = true
[fetch]
        prune = true
        pruneTags = true
[help]
        autocorrect = prompt
[core]
	editor = code --wait
	autocrlf = input
